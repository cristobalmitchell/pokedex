# Load libraries
## 1) Use a clean, user-writable library (avoids permission issues)
dir.create(Sys.getenv("R_LIBS_USER"), showWarnings = FALSE, recursive = TRUE)
.libPaths(c(Sys.getenv("R_LIBS_USER"), .libPaths()))
options(repos = c(CRAN = "https://cloud.r-project.org"))
## 2) Remove any leftover 00LOCK folders (the thing blocking installs)
locks <- unlist(lapply(.libPaths(), function(p) Sys.glob(file.path(p, "00LOCK*"))))
if (length(locks)) unlink(locks, recursive = TRUE, force = TRUE)
## 3) Install in dependency order to stop the cascade
install.packages("sass")      # needed by bslib
install.packages("bslib")     # needed by rmarkdown
install.packages("rmarkdown") # needed by reprex
install.packages("reprex")
install.packages("tidyverse") # the goal
